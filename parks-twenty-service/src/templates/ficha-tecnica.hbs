<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <title>Ficha técnica — {{naveIdentificador}}</title>
  <style>
    body {
      font-family: 'Helvetica Neue', Arial, sans-serif;
      color: #111827;
      margin: 0;
      padding: 32px;
      line-height: 1.5;
    }
    .header {
      border-bottom: 3px solid #2563eb;
      margin-bottom: 24px;
      padding-bottom: 16px;
    }
    .header h1 {
      font-size: 24px;
      margin: 0 0 8px;
    }
    .header p {
      color: #6b7280;
      margin: 0;
    }
    .grid {
      display: grid;
      gap: 16px;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      margin-bottom: 24px;
    }
    .card {
      background: #f9fafb;
      border: 1px solid #e5e7eb;
      border-radius: 8px;
      padding: 16px;
    }
    .label {
      color: #6b7280;
      font-size: 12px;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }
    .value {
      font-size: 18px;
      font-weight: 600;
      margin-top: 4px;
    }
    .note {
      background: #eff6ff;
      border-left: 4px solid #2563eb;
      padding: 12px 16px;
    }
    footer {
      border-top: 1px solid #e5e7eb;
      color: #6b7280;
      font-size: 12px;
      margin-top: 32px;
      padding-top: 12px;
    }
  </style>
</head>
<body>
  <div class="header">
    <h1>Ficha técnica — {{naveIdentificador}}</h1>
    <p>Parks Industrial · Preparado para {{companyName}}</p>
  </div>

  <div class="grid">
    <div class="card">
      <div class="label">Parque industrial</div>
      <div class="value">{{parqueNombre}}</div>
    </div>
    <div class="card">
      <div class="label">Ubicación</div>
      <div class="value">{{ubicacion}}</div>
    </div>
    <div class="card">
      <div class="label">Superficie</div>
      <div class="value">{{m2}} m²</div>
    </div>
    <div class="card">
      <div class="label">Precio referencia</div>
      <div class="value">USD {{precioUsdM2}} / m²</div>
    </div>
  </div>

  <div class="note">
    Renta mensual estimada: <strong>USD {{rentaMensualEstimada}}</strong>
    (referencia comercial sujeta a negociación y condiciones del contrato).
  </div>

  <footer>
    Documento informativo · {{generationDate}} · Parks Industrial / FUNO
  </footer>
</body>
</html>
