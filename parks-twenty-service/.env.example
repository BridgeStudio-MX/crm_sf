# Twenty CRM
TWENTY_API_URL=http://localhost:3000
# Opcional en dev local — si vacío, usa login tim@apple.dev / tim@apple.dev
TWENTY_API_KEY=
TWENTY_DEV_EMAIL=tim@apple.dev
TWENTY_DEV_PASSWORD=tim@apple.dev

# Microservicio — usar 3002 en dev local (3001 = UI Twenty/Vite)
PORT=3002
NODE_ENV=development

# Webhook Twenty → microservicio (Paso 10)
WEBHOOK_URL=http://localhost:3002/webhooks/twenty
# Opcional — si se define, Twenty firma payloads y el microservicio los valida
WEBHOOK_SECRET=

# Seed demo (Paso 12) — FORCE_DEMO_SEED=true para re-ejecutar
FORCE_DEMO_SEED=false

# E2E (Paso 13) — FORCE_E2E_RERUN=true para re-ejecutar flujo completo
FORCE_E2E_RERUN=false

# SLA
DIAS_FESTIVOS_MX=2026-01-01,2026-02-03,2026-03-21,2026-04-02,2026-04-03,2026-05-01,2026-09-16,2026-11-02,2026-11-16,2026-12-25
SLA_PAUSA_POR_DOCS=true

# Comisiones — pendiente confirmar con Parks Industrial
COMISION_EJECUTIVO_PCT=0.03

# Holdover
HOLDOVER_MULTIPLIER=2

# Oracle ERP
ORACLE_API_URL=https://oracle-api.parks-industrial.com
ORACLE_API_KEY=your_oracle_api_key_here
ORACLE_MOCK=true

# Crons (cron syntax)
CRON_SLA_TICKER=0 * * * *
CRON_HOLDOVER_SCANNER=0 8 * * *
CRON_RENOVACION_ALERTS=0 7 * * *
CRON_ORACLE_SYNC=0 */4 * * *
